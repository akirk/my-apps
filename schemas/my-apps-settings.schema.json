{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://github.com/akirk/my-apps/schemas/my-apps-settings.schema.json",
	"title": "My Apps Settings Export",
	"description": "Settings file imported and exported as my-apps-settings.json.",
	"type": "object",
	"properties": {
		"sort": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"hide_plugins": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"additional_apps": {
			"type": "object",
			"propertyNames": {
				"type": "string",
				"minLength": 1
			},
			"additionalProperties": {
				"$ref": "#/$defs/launcherApp"
			}
		},
		"app_icon_overrides": {
			"type": "object",
			"propertyNames": {
				"type": "string",
				"minLength": 1
			},
			"additionalProperties": {
				"$ref": "#/$defs/appIcon"
			}
		},
		"app_overrides": {
			"type": "object",
			"propertyNames": {
				"type": "string",
				"minLength": 1
			},
			"additionalProperties": {
				"$ref": "#/$defs/appOverride"
			}
		},
		"redirect_root": {
			"type": [
				"boolean",
				"string",
				"number"
			],
			"description": "Playground-only setting for whether requests to the site root should redirect to /my-apps/."
		},
		"hide_wp_admin_links": {
			"type": [
				"boolean",
				"string",
				"number"
			],
			"description": "Setting for whether the WordPress logo menu and site name shortcuts should be hidden from the masterbar. Defaults on in Playground."
		},
		"background": {
			"type": "string"
		},
		"custom_background": {
			"type": "string"
		},
		"image_url": {
			"type": "string",
			"format": "uri"
		},
		"attachment_id": {
			"type": "integer",
			"minimum": 0
		},
		"background_image_id": {
			"type": "integer",
			"minimum": 0,
			"description": "Legacy import key accepted for image backgrounds."
		},
		"display": {
			"type": "object",
			"properties": {
				"layout": {
					"type": "string",
					"enum": [
						"flow",
						"grid"
					]
				},
				"icon_size": {
					"$ref": "#/$defs/stringifiedNumber"
				},
				"spacing": {
					"$ref": "#/$defs/stringifiedNumber"
				},
				"grid_columns": {
					"$ref": "#/$defs/stringifiedNumber"
				},
				"custom_blueprints": {
					"type": "string",
					"description": "Serialized custom-blueprints JSON stored by the exporter."
				}
			},
			"additionalProperties": false
		},
		"custom_blueprints": {
			"type": "string",
			"description": "Serialized custom-blueprints JSON accepted by the importer."
		}
	},
	"additionalProperties": true,
	"$defs": {
		"stringifiedNumber": {
			"oneOf": [
				{
					"type": "string",
					"pattern": "^[0-9]+$"
				},
				{
					"type": "number"
				}
			]
		},
		"launcherApp": {
			"type": "object",
			"required": [
				"name",
				"url"
			],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"url": {
					"type": "string",
					"minLength": 1
				},
				"icon_url": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"dashicon": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"emoji": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"gradient": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"user": {
					"type": [
						"integer",
						"null"
					],
					"minimum": 0
				}
			},
			"additionalProperties": true
		},
		"appIcon": {
			"type": "object",
			"properties": {
				"icon_url": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"dashicon": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"emoji": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				},
				"gradient": {
					"type": [
						"string",
						"boolean",
						"null"
					]
				}
			},
			"additionalProperties": true
		},
		"appOverride": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string",
					"minLength": 1
				},
				"url": {
					"type": "string",
					"minLength": 1
				}
			},
			"additionalProperties": false,
			"anyOf": [
				{
					"required": [
						"name"
					]
				},
				{
					"required": [
						"url"
					]
				}
			]
		}
	}
}
